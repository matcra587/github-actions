{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "paths": {
      "@validate-skills/*": ["./src/*"]
    },
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun", "node"],
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts"]
}
