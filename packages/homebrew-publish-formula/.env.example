INPUT_TOKEN=dummy
INPUT_TAP=matcra587/homebrew-tap
INPUT_NAME=peerscout
INPUT_DESC=Fetch live peers for Cosmos SDK chains
INPUT_HOMEPAGE=https://github.com/matcra587/peerscout
INPUT_VERSION=v0.4.1
INPUT_CHECKSUMS-FILE=__fixtures__/peerscout-checksums.txt
INPUT_PLATFORMS=darwin/arm64,linux/amd64,linux/arm64
INPUT_MODULE-PATH=github.com/matcra587/peerscout
INPUT_BUILD-PACKAGE=.
INPUT_HEAD-BRANCH=main
INPUT_HEAD-DEPENDS-ON=go
INPUT_COMPLETION-ARGS=completion
INPUT_TEST-ARGS=version
INPUT_TEST-MATCH={version}
INPUT_DRY-RUN=true
INPUT_LIVECHECK=true
