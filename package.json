{
  "name": "@matcra587/github-actions",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "all": "bun run quality && bun run homebrew:all",
    "homebrew:all": "cd packages/homebrew-publish-formula && bun run all",
    "homebrew:bundle": "cd packages/homebrew-publish-formula && bun run bundle",
    "homebrew:local": "ROOT=$PWD; cd packages/homebrew-publish-formula && PATH=\"$ROOT/node_modules/.bin:$PATH\" local-action . src/main.ts .env.example",
    "homebrew:test": "cd packages/homebrew-publish-formula && bun run test",
    "homebrew:typecheck": "cd packages/homebrew-publish-formula && bun run typecheck",
    "quality": "biome ci .",
    "quality:fix": "biome check --write ."
  },
  "devDependencies": {
    "@actions/artifact": "6.2.1",
    "@actions/cache": "6.0.0",
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "@biomejs/biome": "2.4.14",
    "@github/local-action": "7.0.1",
    "tsx": "4.21.0"
  }
}
